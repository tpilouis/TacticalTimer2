/**
 * @file    credentials.h.example
 * @brief   Wi-Fi credentials template for TacticalTimer2
 *
 * INSTRUCTIONS:
 *  1. Copy this file:  cp credentials.h.example credentials.h
 *  2. Fill in your Wi-Fi SSID and password below
 *  3. credentials.h is in .gitignore and will NOT be committed
 *
 * NOTE:
 *  If the Wi-Fi connection fails at boot (wrong credentials, router
 *  not available, or outdoors), TacticalTimer2 automatically falls
 *  back to AP (Access Point) mode:
 *    - Hotspot SSID:     TacticalTimer2
 *    - Hotspot Password: tt2admin
 *    - Dashboard URL:    http://192.168.4.1
 *
 *  AP credentials can be changed in config.h → NetCfg::AP_SSID / AP_PASSWORD
 */

#pragma once
#define WIFI_SSID     "your_wifi_ssid_here"
#define WIFI_PASSWORD "your_wifi_password_here"
